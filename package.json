{
  "name": "tricho-app",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run --config vitest.config.unit.ts && vitest run --config vitest.config.component.ts",
    "test:watch": "vitest --config vitest.config.unit.ts",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:component": "vitest run --config vitest.config.component.ts",
    "test:backend": "vitest run --config vitest.config.backend.ts",
    "test:backend:integration": "vitest run --config vitest.config.integration.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --config=playwright.prototype-ui.config.ts",
    "test:smoke": "bash scripts/smoke/run-all.sh",
    "test:all": "npm run test:unit && npm run test:component && npm run test:backend && npm run test:backend:integration && npm run test:smoke && npm run test:e2e",
    "test:coverage": "vitest run --config vitest.config.unit.ts --coverage && vitest run --config vitest.config.component.ts --coverage && vitest run --config vitest.config.backend.ts --coverage",
    "typecheck": "astro check && tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/react": "^4.1.0",
    "@nanostores/react": "^1.0.0",
    "@vite-pwa/astro": "^1.0.0",
    "astro": "^5.16.5",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "nanostores": "^1.0.0",
    "pouchdb-adapter-memory": "^9.0.0",
    "pouchdb-browser": "^9.0.0",
    "pouchdb-find": "^9.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@inlang/paraglide-js": "^2.16.1",
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/pouchdb-adapter-memory": "^6.1.6",
    "@types/pouchdb-browser": "^6.1.5",
    "@types/pouchdb-find": "^7.3.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.0.0",
    "testcontainers": "^11.14.0",
    "vitest": "^3.0.0"
  }
}
