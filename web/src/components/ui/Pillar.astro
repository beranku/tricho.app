---
interface Props {
  label: string;
  html: string;
}
const { label, html } = Astro.props;
---

<div class="pillar">
  <div class="pillar-label">{label}</div>
  <p set:html={html} />
</div>

<style>
  .pillar { display: flex; flex-direction: column; gap: 10px; }
  .pillar-label {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 16px;
    color: var(--ink);
    letter-spacing: -0.015em;
  }
  .pillar p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-3);
    max-width: 28ch;
    margin: 0;
  }
  .pillar :global(code) {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 12px;
    color: var(--ink-2);
    background: var(--surface);
    padding: 1px 5px;
    border-radius: 3px;
    border: 1px solid var(--line);
  }
</style>
