---
interface Props {
  quoteHtml: string;
  initials: string;
  name: string;
  role: string;
  photoSrc?: string;
}
const { quoteHtml, initials, name, role, photoSrc } = Astro.props;
---

<figure class="voice">
  <blockquote set:html={quoteHtml} />
  <figcaption>
    {photoSrc ? (
      <img class="voice-photo" src={photoSrc} alt={name} loading="lazy" width="44" height="44" />
    ) : (
      <div class="voice-avatar" aria-hidden="true">{initials}</div>
    )}
    <div class="voice-meta">
      <div class="voice-name">{name}</div>
      <div class="voice-role">{role}</div>
    </div>
  </figcaption>
</figure>

<style>
  .voice {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    padding: 28px 26px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin: 0;
  }
  blockquote {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 300;
    font-size: 17px;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: var(--ink);
    flex: 1;
    margin: 0;
  }
  blockquote :global(em) {
    font-style: italic;
    color: var(--teal-700);
    font-weight: 300;
  }
  blockquote::before {
    content: '\201E';
    color: var(--copper);
    font-size: 1.1em;
    line-height: 0;
    vertical-align: -0.4em;
    margin-right: 0.05em;
  }
  blockquote::after {
    content: '\201C';
    color: var(--copper);
    font-size: 1.1em;
    line-height: 0;
    vertical-align: -0.4em;
    margin-left: 0.05em;
  }
  figcaption {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 18px;
    border-top: 1px solid var(--line-2);
  }
  .voice-avatar,
  .voice-photo {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .voice-avatar {
    background: linear-gradient(135deg, var(--copper-soft) 0%, var(--cream) 100%);
    border: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Fraunces', Georgia, serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--copper-deep);
    letter-spacing: -0.01em;
  }
  .voice-photo { object-fit: cover; }
  .voice-name {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 14px;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .voice-role {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 10px;
    color: var(--ink-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 2px;
  }
</style>
