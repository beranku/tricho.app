---
import PhoneStatusBar from './PhoneStatusBar.astro';
import type { PhoneSlot } from '../../content/landing';

interface Props {
  time: string;
  weatherIcon?: boolean;
  kicker: string;
  temperature?: string;
  main: string;
  slots: PhoneSlot[];
  divider: { label: string; main: string };
  tomorrow: PhoneSlot[];
  showHamburger?: boolean;
}
const {
  time,
  weatherIcon = false,
  kicker,
  temperature = '',
  main,
  slots,
  divider,
  tomorrow,
  showHamburger = true,
} = Astro.props;
---

<PhoneStatusBar time={time} />

<div class="phone-chrome">
  {showHamburger && (
    <div class="phone-glyph" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <line x1="4" y1="8" x2="20" y2="8" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="16" x2="20" y2="16" />
      </svg>
    </div>
  )}
  <div class="phone-glyph" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
      <circle cx="5" cy="12" r="1.6" />
      <circle cx="12" cy="12" r="1.6" />
      <circle cx="19" cy="12" r="1.6" />
    </svg>
  </div>
</div>

<div class="phone-day-header">
  {weatherIcon && (
    <span class="weather-sun" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M 8.5 9 Q 7.8 12.2 9.8 14.4 Q 12 15.8 14.3 14.4 Q 16 12 14.6 9.5 Q 12.5 8 10 8.4 Q 8.9 8.7 8.5 9 Z" />
        <path d="M 12 3 L 12 5.2" />
        <path d="M 12 18.8 L 12 21" />
        <path d="M 3 12 L 5.2 12" />
        <path d="M 18.8 12 L 21 12" />
        <path d="M 5.4 5.4 L 7 7" />
        <path d="M 17 17 L 18.6 18.6" />
        <path d="M 5.4 18.6 L 7 17" />
        <path d="M 17 7 L 18.6 5.4" />
      </svg>
    </span>
  )}
  <span class="phone-kicker">
    {kicker}
    {temperature && <span class="phone-day-temp">{temperature}</span>}
  </span>
  <div class="phone-day-main">{main}</div>
</div>

{slots.map((slot) => (
  slot.kind === 'free' ? (
    <div class="phone-slot">
      <span class="time dim">{slot.time}</span>
      <span class="slot-free">{slot.freeText}</span>
      <span class="slot-plus">+</span>
    </div>
  ) : (
    <div class={`phone-slot${slot.status === 'done' ? ' done' : ''}${slot.status === 'active' ? ' active' : ''}`}>
      <span class="time">{slot.time}</span>
      <div>
        <div class="slot-name">{slot.name}</div>
        <div class="slot-sub">{slot.subtitle}</div>
      </div>
      {slot.status === 'done' ? (
        <span class="check" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M2.8 7.2 C 3.8 8.6, 4.8 9.6, 5.7 10.2 C 6.5 8.3, 8.7 5.4, 11.4 2.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
      ) : <span></span>}
    </div>
  )
))}

<div class="phone-divider">
  <span class="line"></span>
  <span class="phone-kicker copper">{divider.label}</span>
  <span class="line"></span>
</div>
<div class="phone-divider-main">{divider.main}</div>

{tomorrow.map((slot) => (
  slot.kind === 'free' ? (
    <div class="phone-slot">
      <span class="time dim">{slot.time}</span>
      <span class="slot-free">{slot.freeText}</span>
      <span class="slot-plus">+</span>
    </div>
  ) : (
    <div class="phone-slot">
      <span class="time">{slot.time}</span>
      <div>
        <div class="slot-name">{slot.name}</div>
        <div class="slot-sub">{slot.subtitle}</div>
      </div>
      <span></span>
    </div>
  )
))}

<style>
  .phone-chrome {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 12px 10px;
    min-height: 48px;
  }
  .phone-glyph {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-2);
  }
  .phone-day-header { text-align: center; padding: 0 16px 14px; position: relative; }
  .weather-sun { position: absolute; left: 24px; top: 4px; color: var(--copper); opacity: 0.85; }
  .phone-kicker {
    display: block;
    font-family: 'Geist', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--teal-600);
    margin-bottom: 6px;
  }
  .phone-kicker.copper { color: var(--copper); margin: 0; }
  .phone-day-main {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 18px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  .phone-day-temp {
    font-size: 9px;
    color: var(--ink-4);
    margin-left: 4px;
    vertical-align: middle;
  }

  .phone-slot {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    align-items: start;
    padding: 12px 20px;
    gap: 12px;
    min-height: 54px;
  }
  .phone-slot .time {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }
  .phone-slot .time.dim { color: var(--ink-4); }
  .phone-slot .slot-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 2px;
  }
  .phone-slot .slot-sub { font-size: 12px; color: var(--ink-3); }
  .phone-slot .slot-free {
    font-family: 'Patrick Hand', cursive;
    font-size: 14px;
    color: var(--ink-3);
  }
  .phone-slot .slot-plus {
    font-family: 'Caveat', cursive;
    font-size: 24px;
    font-weight: 600;
    color: var(--copper);
    line-height: 1;
  }
  .phone-slot.done .slot-name,
  .phone-slot.done .slot-sub,
  .phone-slot.done .time { color: var(--ink-3); }
  .phone-slot.done .slot-name {
    text-decoration: line-through;
    text-decoration-color: var(--ink-4);
  }
  .phone-slot.done .check { color: var(--copper-deep); }
  .phone-slot.active {
    margin: 4px;
    background: rgba(14, 116, 144, 0.06);
    border: 1px solid rgba(14, 116, 144, 0.22);
    border-radius: 14px;
    padding: 12px 16px;
  }
  :global(:root[data-theme='dark']) .phone-slot.active {
    background: rgba(36, 148, 178, 0.12);
    border-color: rgba(36, 148, 178, 0.28);
  }
  .phone-slot.active .slot-name,
  .phone-slot.active .time { color: var(--teal-900); }
  .phone-slot.active .slot-sub { color: var(--teal-700); }
  :global(:root[data-theme='dark']) .phone-slot.active .slot-name,
  :global(:root[data-theme='dark']) .phone-slot.active .time { color: var(--teal-700); }
  :global(:root[data-theme='dark']) .phone-slot.active .slot-sub { color: var(--teal-600); }

  .phone-divider {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 18px 20px 8px;
  }
  .phone-divider .line { flex: 1; height: 1px; background: var(--line); }
  .phone-divider-main {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 17px;
    font-weight: 500;
    text-align: center;
    color: var(--ink);
    letter-spacing: -0.02em;
    margin: -4px 0 4px;
  }
</style>
