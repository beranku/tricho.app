---
interface Props {
  variant?: 'full' | 'mini';
}
const { variant = 'full' } = Astro.props;
const className = variant === 'mini' ? 'phone-mock mini-phone' : 'phone-mock';
---

<div class={className}>
  <div class="phone-screen">
    <div class="phone-island" aria-hidden="true"></div>
    <slot />
  </div>
</div>

<style>
  .phone-mock {
    width: 100%;
    max-width: 340px;
    margin: 0 auto;
    background: var(--phone-frame);
    border-radius: 44px;
    padding: 8px;
    box-shadow: var(--phone-shadow);
    position: relative;
  }
  .phone-mock.mini-phone {
    max-width: 300px;
    border-radius: 38px;
    padding: 7px;
  }
  .phone-screen {
    background: var(--bg);
    border-radius: 38px;
    overflow: hidden;
    height: 600px;
    position: relative;
  }
  .mini-phone .phone-screen {
    height: 540px;
    border-radius: 32px;
  }
  .phone-screen::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--paper-grain);
    background-size: 200px 200px;
    mix-blend-mode: var(--paper-blend);
    opacity: var(--paper-opacity);
    pointer-events: none;
  }
  .phone-island {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 90px;
    height: 24px;
    background: var(--island-fill);
    border-radius: 14px;
    z-index: var(--z-dv-a);
  }
  .mini-phone .phone-island {
    width: 76px;
    height: 20px;
    border-radius: 12px;
    top: 8px;
  }
</style>
