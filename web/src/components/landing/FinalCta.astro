---
import InviteForm from './InviteForm.astro';
import { finalCta } from '../../content/landing';
---

{/* Anchor "pozvanka" replaces the old "stahnout" — every CTA on the page
    points here while the app is invite-only. */}
<section class="final-cta" id="pozvanka">
  <div class="page">
    <h2 set:html={finalCta.titleHtml} />
    <p class="lede">{finalCta.lede}</p>
    <div class="form-wrap">
      <InviteForm align="center" />
    </div>
    <p class="risk-reversal">{finalCta.riskReversal}</p>
    <div class="micro">{finalCta.micro}</div>
  </div>
</section>

<style>
  .final-cta {
    text-align: center;
    padding: 88px 0 96px;
    border-top: 1px solid var(--line);
    position: relative;
  }
  .final-cta h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 300;
    font-size: clamp(30px, 4.2vw, 44px);
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--ink);
    margin: 0 auto 24px;
    max-width: 22ch;
    font-variation-settings: 'opsz' 36;
  }
  .final-cta h2 :global(em) {
    font-style: italic;
    color: var(--teal-700);
  }
  .final-cta .lede {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-3);
    max-width: 46ch;
    margin: 0 auto 28px;
  }
  .final-cta .form-wrap {
    display: flex;
    justify-content: center;
  }
  .final-cta .risk-reversal {
    margin: 28px auto 0;
    font-family: 'Patrick Hand', cursive;
    font-size: 15px;
    color: var(--ink-3);
    line-height: 1.5;
    max-width: 46ch;
  }
  .final-cta .micro {
    margin-top: 28px;
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 10px;
    color: var(--ink-4);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
</style>
