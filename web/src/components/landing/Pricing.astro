---
import SectionHead from '../ui/SectionHead.astro';
import PlanCell from '../ui/PlanCell.astro';
import { pricing } from '../../content/landing';
---

<section id="plany" class="landing-section">
  <div class="page">
    <SectionHead num={pricing.num} titleHtml={pricing.titleHtml} sub={pricing.sub} />

    <div class="free-block">
      <div class="free-head">
        <div class="label">{pricing.free.label}</div>
        <h3 set:html={pricing.free.titleHtml} />
        <p>{pricing.free.text}</p>
        <a href={pricing.free.ctaHref} class="btn-primary">{pricing.free.ctaLabel}</a>
      </div>
      <ul class="free-features">
        {pricing.free.features.map((f) => <li>{f}</li>)}
      </ul>
    </div>

    <div class="plans-intro">
      <div class="label">{pricing.plansIntro.label}</div>
      <h3 set:html={pricing.plansIntro.titleHtml} />
      <p>{pricing.plansIntro.text}</p>
    </div>

    <div class="plans-grid">
      {pricing.plans.map((plan) => (
        <PlanCell
          name={plan.name}
          amount={plan.amount}
          period={plan.period}
          tag={plan.tag}
          features={plan.features}
          microcopy={plan.microcopy}
        />
      ))}
    </div>

    <p class="price-fineprint">{pricing.fineprint}</p>
  </div>
</section>

<style>
  .free-block {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    padding: 48px;
    margin-bottom: 28px;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 56px;
    align-items: center;
  }
  @media (max-width: 800px) {
    .free-block { grid-template-columns: 1fr; gap: 32px; padding: 32px 24px; }
  }
  .free-head .label {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--copper);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 18px;
  }
  .free-head h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 300;
    font-size: clamp(28px, 3.4vw, 38px);
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--ink);
    margin: 0 0 14px;
  }
  .free-head h3 :global(em) {
    font-style: italic;
    color: var(--teal-700);
    font-weight: 300;
  }
  .free-head p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-3);
    max-width: 36ch;
    margin: 0 0 22px;
  }
  .free-features {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 24px;
    padding: 0 0 0 32px;
    margin: 0;
    border-left: 1px solid var(--line);
  }
  @media (max-width: 800px) {
    .free-features {
      padding: 24px 0 0;
      border-left: none;
      border-top: 1px solid var(--line);
      grid-template-columns: 1fr;
    }
  }
  .free-features li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13px;
    color: var(--ink-2);
    line-height: 1.5;
  }
  .free-features li::before {
    content: '+';
    color: var(--copper);
    flex-shrink: 0;
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-weight: 500;
  }

  .plans-intro {
    margin: 56px 0 28px;
    display: flex;
    align-items: baseline;
    gap: 20px;
    flex-wrap: wrap;
  }
  .plans-intro .label {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--copper);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
  }
  .plans-intro h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 400;
    font-size: clamp(22px, 2.6vw, 28px);
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1.2;
    margin: 0;
  }
  .plans-intro h3 :global(em) {
    font-style: italic;
    color: var(--teal-700);
    font-weight: 300;
  }
  .plans-intro p {
    font-size: 14px;
    color: var(--ink-3);
    margin-left: auto;
    max-width: 40ch;
    line-height: 1.55;
  }
  @media (max-width: 800px) {
    .plans-intro p { margin-left: 0; }
  }

  .plans-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    overflow: hidden;
  }
  @media (max-width: 720px) {
    .plans-grid { grid-template-columns: 1fr; }
  }

  .price-fineprint {
    margin: 28px auto 0;
    text-align: center;
    font-size: 12px;
    color: var(--ink-3);
    line-height: 1.7;
    max-width: 60ch;
  }
</style>
