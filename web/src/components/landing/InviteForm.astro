---
// Invite-request form. Posts directly to Brevo's hosted form endpoint
// via fetch — no embed, no iframe, no third-party script. The form
// works without JavaScript too: native HTML form submission falls back
// to Brevo's own thank-you page (the action URL is the same).
//
// `mode: 'no-cors'` is intentional. Brevo's `/serve/<id>` endpoint
// accepts `multipart/form-data` POSTs but does not return CORS headers
// for AJAX origins. With `no-cors` the request still reaches Brevo;
// the response is opaque, so we treat any non-network-error completion
// as success. Actual delivery is verifiable in the Brevo contact list.
import { inviteForm } from '../../content/landing';

const BREVO_URL = 'https://2f4a10db.sibforms.com/serve/MUIFAPmANqJZWwB7JosYLw761lpxAhjY-E4Kuu5n9be6mc7OkB3i7F3ZS2CF9JsKfwp3rE3OVXWYr71SvtDPL3QK2zUE0zeEuQ_JtJih0eDdZadlVO9_Uy7VFCtghTGy1QmknJAje0DdK7_eVzJKfBXUcAhwFHsSpHxgClgjY5qnQ_Vo67JJy5CID4O0LbPXAxtTYzVNDYPSogUg2Q==';

interface Props {
  align?: 'left' | 'center';
}
const { align = 'center' } = Astro.props;
---

<form
  class:list={['invite-form', `invite-form--${align}`]}
  action={BREVO_URL}
  method="POST"
  data-invite-form
  novalidate
>
  <label class="sr-only" for="invite-email">{inviteForm.label}</label>

  <div class="invite-row">
    <input
      class="invite-input"
      type="email"
      id="invite-email"
      name="EMAIL"
      placeholder={inviteForm.placeholder}
      required
      autocomplete="email"
      inputmode="email"
      spellcheck="false"
    />
    <button type="submit" class="invite-submit btn-primary">
      <span class="invite-submit-label">{inviteForm.submitLabel}</span>
      <span class="invite-spinner" aria-hidden="true"></span>
    </button>
  </div>

  {/* Toggle for the Brevo `JOIN_TESTING` attribute. Rendered as a radio
      group for clarity (one option must always be selected); the submit
      handler translates the chosen value to `JOIN_TESTING=1` only when
      the testing option is picked, mirroring Brevo's checkbox semantics. */}
  <fieldset class="invite-choice">
    <legend class="invite-choice__legend">{inviteForm.choice.legend}</legend>
    <label class="invite-choice__option">
      <input type="radio" name="join_choice" value="testing" />
      <span class="invite-choice__bullet" aria-hidden="true"></span>
      <span class="invite-choice__text">{inviteForm.choice.testing}</span>
    </label>
    <label class="invite-choice__option">
      <input type="radio" name="join_choice" value="wait" checked />
      <span class="invite-choice__bullet" aria-hidden="true"></span>
      <span class="invite-choice__text">{inviteForm.choice.wait}</span>
    </label>
  </fieldset>

  <p class="invite-helper">{inviteForm.helper}</p>

  <p class="invite-status invite-status--ok" data-invite-status="ok" hidden role="status">
    {inviteForm.successMessage}
  </p>
  <p class="invite-status invite-status--err" data-invite-status="err" hidden role="alert">
    {inviteForm.errorMessage}
  </p>

  {/* Brevo honeypot + locale + format. Hidden inputs the endpoint expects. */}
  <input type="text" name="email_address_check" value="" tabindex="-1" autocomplete="off" class="invite-honeypot" aria-hidden="true" />
  <input type="hidden" name="locale" value="cs" />
  <input type="hidden" name="html_type" value="simple" />
</form>

<style>
  .invite-form {
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
    max-width: 480px;
  }
  .invite-form--center {
    margin-left: auto;
    margin-right: auto;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* One-row input + button. Wraps on narrow screens. */
  .invite-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: stretch;
  }

  .invite-input {
    flex: 1 1 240px;
    min-width: 0;
    padding: 12px 16px;
    border-radius: var(--radius-ctrl);
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--ink);
    font-family: 'Geist', system-ui, sans-serif;
    font-size: 15px;
    line-height: 1.4;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .invite-input::placeholder { color: var(--ink-4); }
  .invite-input:focus {
    outline: none;
    border-color: var(--teal-700);
    box-shadow: 0 0 0 3px rgba(14, 116, 144, 0.12);
  }
  .invite-input:invalid:not(:placeholder-shown) {
    border-color: var(--copper);
  }

  /* Inherit the global .btn-primary look (teal-700 bg, white label,
   * radius-ctrl) so the form button is visually identical to every other
   * primary CTA on the page. We only add behaviour the global rule
   * doesn't cover: spinner state + relative positioning. */
  .invite-submit {
    position: relative;
    flex: 0 0 auto;
    min-height: auto;
  }
  .invite-submit[disabled] { opacity: 0.65; cursor: progress; }

  .invite-spinner {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid currentColor;
    border-right-color: transparent;
    animation: invite-spin 0.7s linear infinite;
    display: none;
  }
  .invite-form[data-state='loading'] .invite-spinner { display: inline-block; }
  .invite-form[data-state='loading'] .invite-submit-label { opacity: 0.6; }
  @keyframes invite-spin { to { transform: rotate(360deg); } }

  .invite-helper {
    font-family: 'Patrick Hand', cursive;
    font-size: 14px;
    color: var(--ink-3);
    line-height: 1.4;
    margin: 0;
  }
  .invite-form--center .invite-helper { text-align: center; }

  .invite-status {
    margin: 0;
    padding: 10px 14px;
    border-radius: var(--radius-ctrl);
    font-family: 'Geist', system-ui, sans-serif;
    font-size: 14px;
    line-height: 1.4;
  }
  .invite-status--ok {
    background: var(--teal-tint);
    border: 1px solid var(--teal-border);
    color: var(--teal-strong);
  }
  .invite-status--err {
    background: var(--copper-tint);
    border: 1px solid var(--copper-border);
    color: var(--copper-mid);
  }

  /* Honeypot off-screen but still focusable for bots that ignore display:none. */
  .invite-honeypot {
    position: absolute;
    left: -10000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
  }

  /* Testing toggle. Native radio inputs are visually hidden; the
   * .invite-choice__bullet draws the dot. */
  .invite-choice {
    border: 0;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .invite-choice__legend {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .invite-choice__option {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    cursor: pointer;
    padding: 6px 4px;
    border-radius: var(--radius-ctrl);
    transition: background var(--t-hover);
  }
  .invite-choice__option:hover {
    background: var(--copper-tint);
  }
  .invite-choice__option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .invite-choice__bullet {
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
    margin-top: 2px;
    border-radius: 50%;
    border: 1.5px solid var(--ink-4);
    background: var(--surface);
    position: relative;
    transition: border-color var(--t-base);
  }
  .invite-choice__option input:checked ~ .invite-choice__bullet {
    border-color: var(--teal);
  }
  .invite-choice__option input:checked ~ .invite-choice__bullet::after {
    content: '';
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    background: var(--teal);
  }
  .invite-choice__option input:focus-visible ~ .invite-choice__bullet {
    box-shadow: 0 0 0 3px rgba(14, 116, 144, 0.18);
  }
  .invite-choice__text {
    font-family: 'Geist', system-ui, sans-serif;
    font-size: 14px;
    line-height: 1.4;
    color: var(--ink-2);
    text-align: left;
  }
  .invite-form--center .invite-choice {
    text-align: left;
    max-width: 440px;
    margin: 0 auto;
    width: 100%;
  }
</style>

<script>
  const BREVO_URL =
    'https://2f4a10db.sibforms.com/serve/MUIFAPmANqJZWwB7JosYLw761lpxAhjY-E4Kuu5n9be6mc7OkB3i7F3ZS2CF9JsKfwp3rE3OVXWYr71SvtDPL3QK2zUE0zeEuQ_JtJih0eDdZadlVO9_Uy7VFCtghTGy1QmknJAje0DdK7_eVzJKfBXUcAhwFHsSpHxgClgjY5qnQ_Vo67JJy5CID4O0LbPXAxtTYzVNDYPSogUg2Q==';

  document.querySelectorAll<HTMLFormElement>('[data-invite-form]').forEach((form) => {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const input = form.querySelector<HTMLInputElement>('input[name="EMAIL"]');
      const okStatus = form.querySelector<HTMLElement>('[data-invite-status="ok"]');
      const errStatus = form.querySelector<HTMLElement>('[data-invite-status="err"]');
      const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]');

      if (!input || !input.value || !input.checkValidity()) {
        input?.focus();
        input?.reportValidity();
        return;
      }

      // Clear previous status, set loading state.
      if (okStatus) okStatus.hidden = true;
      if (errStatus) errStatus.hidden = true;
      form.dataset.state = 'loading';
      if (submit) submit.disabled = true;

      // Translate the radio-group choice into Brevo's `JOIN_TESTING`
      // checkbox field: `JOIN_TESTING=1` only when the testing option is
      // selected; otherwise the field is omitted entirely.
      const formData = new FormData(form);
      const choice = formData.get('join_choice');
      formData.delete('join_choice');
      if (choice === 'testing') {
        formData.set('JOIN_TESTING', '1');
      }

      try {
        await fetch(BREVO_URL, {
          method: 'POST',
          mode: 'no-cors',
          body: formData,
        });
        // With no-cors the response is opaque; we cannot read status. Treat
        // any completion without a network error as success. Verifiable in
        // the Brevo dashboard contact list.
        if (okStatus) okStatus.hidden = false;
        form.reset();
      } catch (_err) {
        if (errStatus) errStatus.hidden = false;
      } finally {
        form.dataset.state = '';
        if (submit) submit.disabled = false;
      }
    });
  });
</script>
