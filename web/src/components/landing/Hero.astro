---
import PhoneFrame from '../phone/PhoneFrame.astro';
import ContentClientReal from '../phone/ContentClientReal.astro';
import { hero, header, realClient } from '../../content/landing';
---

<section class="hero">
  <div class="page">
    <div class="hero-grid">
      <div>
        <div class="hero-eyebrow">{hero.eyebrow}</div>
        <h1 class="hero-title" set:html={hero.titleHtml} />
        <p class="hero-lede">{hero.lede}</p>
        <div class="hero-ctas">
          <a href={header.ctaHref} class="btn-primary">{header.ctaLabel}</a>
        </div>
        <div class="hero-meta">
          {hero.meta.map((m) => <span>{m}</span>)}
        </div>
      </div>

      <div>
        <PhoneFrame variant="full">
          <ContentClientReal
            time={realClient.time}
            islandSize="full"
            clientName={realClient.clientName}
            serviceLabel={realClient.serviceLabel}
            allergen={realClient.allergen}
            remainingLabel={realClient.remainingLabel}
            thumbs={realClient.thumbs}
            services={realClient.services}
            products={realClient.products}
            note={realClient.note}
            nextTermLabel={realClient.nextTermLabel}
          />
        </PhoneFrame>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    /* Sit closer to the header — the previous 96-px landing-section
     * rhythm is too airy when the section is the very first one and
     * there's no install banner above it. */
    padding: 56px 0 72px;
    position: relative;
  }
  @media (max-width: 800px) {
    .hero { padding: 48px 0 64px; }
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  @media (max-width: 880px) {
    .hero-grid { grid-template-columns: 1fr; gap: 56px; }
  }
  .hero-eyebrow {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--copper);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 28px;
  }
  h1.hero-title {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 300;
    font-size: clamp(40px, 5.5vw, 64px);
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: var(--ink);
    font-variation-settings: 'opsz' 36;
    margin: 0 0 32px;
  }
  h1.hero-title :global(em) {
    font-style: italic;
    font-weight: 300;
    color: var(--teal-700);
  }
  .hero-lede {
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 46ch;
    margin: 0 0 36px;
  }
  .hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .hero-meta {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 10px;
    color: var(--ink-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .hero-meta span::before {
    content: '·';
    color: var(--ink-4);
    margin-right: 14px;
  }
  .hero-meta span:first-child::before { content: ''; margin: 0; }
</style>
