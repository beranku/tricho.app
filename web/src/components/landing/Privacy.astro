---
import SectionHead from '../ui/SectionHead.astro';
import Pillar from '../ui/Pillar.astro';
import { privacy } from '../../content/landing';
---

<section class="privacy-quiet landing-section">
  <div class="page">
    <SectionHead num={privacy.num} titleHtml={privacy.titleHtml} />

    <div class="privacy-prose">
      {privacy.prose.map((p) => (
        p.kind === 'lift'
          ? <p class="lift" set:html={p.html} />
          : <p set:html={p.html} />
      ))}
    </div>

    <div class="privacy-pillars">
      {privacy.pillars.map((p) => (
        <Pillar label={p.label} html={p.html} />
      ))}
    </div>
  </div>
</section>

<style>
  .privacy-quiet {
    background: var(--cream-2);
    border-top: 1px solid var(--line-2);
    border-bottom: 1px solid var(--line-2);
  }
  .privacy-prose {
    max-width: 56ch;
    margin-bottom: 56px;
  }
  .privacy-prose p {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 300;
    font-size: clamp(20px, 2.4vw, 26px);
    line-height: 1.45;
    letter-spacing: -0.015em;
    color: var(--ink-2);
    margin: 0 0 18px;
  }
  .privacy-prose p :global(em) {
    font-style: italic;
    color: var(--teal-700);
    font-weight: 300;
  }
  .privacy-prose p.lift {
    color: var(--ink);
    margin: 28px 0;
    padding-left: 24px;
    border-left: 2px solid var(--copper);
  }
  .privacy-prose :global(.hand-soft) {
    font-family: 'Patrick Hand', cursive;
    font-size: 0.95em;
    color: var(--copper-deep);
  }
  .privacy-prose :global(code) {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.7em;
    color: var(--ink-2);
    background: var(--surface);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--line);
    vertical-align: 1px;
  }
  .privacy-pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    padding-top: 32px;
    border-top: 1px solid var(--line);
  }
  @media (max-width: 720px) {
    .privacy-pillars { grid-template-columns: 1fr; gap: 24px; }
  }
</style>
