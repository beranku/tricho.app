---
import ThemeToggle from '../ui/ThemeToggle.astro';
import { header } from '../../content/landing';
---

{/*
  Class is intentionally `.landing-header` (not `.site-header`) to avoid the
  global `web/src/styles/site.css` rule
    `.site-header { max-width: 1120px; margin: 0 auto; }`
  which constrains the header and visually cuts off its bottom border on
  the landing page. Other marketing pages still use `.site-header`.
*/}
<header class="landing-header">
  <div class="page">
    <nav class="nav" aria-label="Hlavní navigace">
      <a href="/" class="brand">
        <span class="brand-name">{header.brandName}</span>
        <span class="brand-kicker">{header.brandKicker}</span>
        <span class="brand-version">{header.brandVersion}</span>
      </a>
      <ul class="nav-links">
        {header.navLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
      <div class="header-actions">
        <ThemeToggle label={header.themeToggleLabel} />
        <a href={header.ctaHref} class="btn-primary">{header.ctaLabelShort}</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .landing-header {
    width: 100%;
    border-bottom: 1px solid var(--line);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0;
  }
  .brand {
    text-decoration: none;
    display: flex;
    align-items: baseline;
    gap: 0;
  }
  .brand-name {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 400;
    font-size: 22px;
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  /* Kicker sits next to the wordmark and is shifted up to roughly the
   * cap-height of "Tricho" — visually it floats above the name's baseline
   * like a superscript hint, while keeping `.app` legible at kicker size. */
  .brand-kicker {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 10px;
    color: var(--copper);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
    align-self: baseline;
    transform: translateY(-0.85em);
  }
  .brand-version {
    font-family: 'Caveat', cursive;
    font-size: 18px;
    font-weight: 400;
    color: var(--ink-4);
    line-height: 1;
    margin-left: 10px;
  }
  .nav-links {
    display: flex;
    gap: 28px;
    align-items: center;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-links a {
    color: var(--ink-2);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--copper); }
  @media (max-width: 720px) {
    .nav-links { display: none; }
  }
  .header-actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }
</style>
