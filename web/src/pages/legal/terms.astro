---
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
---

<Base
  title="Obchodní podmínky — Tricho"
  description="Smluvní podmínky používání Tricho."
  noIndex={true}
>
  <SiteHeader />

  <main>
    <h1>Obchodní podmínky</h1>
    <p style="background: var(--copper-tint); border: 1px solid var(--copper-border); padding: 16px; border-radius: var(--radius-card);">
      <strong>Pracujeme na finální verzi.</strong> Otázky: <a href="mailto:info@tricho.app">info@tricho.app</a>.
    </p>
  </main>

  <SiteFooter />
</Base>
