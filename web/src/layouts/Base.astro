---
// Base layout for the tricho.app marketing surface (everything outside /app/).
// Owns the entire <head>: SEO metadata, Open Graph, Twitter Card, JSON-LD,
// the link to the shared Web App Manifest, the thin pass-through SW
// registration, and the iOS install banner reveal logic.
//
// Pages MUST pass props (title/description) and MUST NOT hand-write <meta>
// tags — that drift is exactly what this layout exists to prevent.

import '../styles/tokens.css';
import '../styles/site.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noIndex?: boolean;
  jsonLd?: Record<string, unknown>[];
  bodyClass?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og/default.png',
  ogType = 'website',
  noIndex = false,
  jsonLd = [],
  bodyClass,
} = Astro.props;

const SITE = 'https://tricho.app';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE).toString();
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${SITE}${ogImage}`;

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Tricho',
  url: SITE,
  logo: `${SITE}/icons/icon-512.png?v=2`,
};

const allJsonLd = [orgJsonLd, ...jsonLd];
---

<!DOCTYPE html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <!-- FOUC-safe theme init. Runs before any CSS so dark mode applies on the
         first paint. Reads localStorage['tricho-theme']; falls back to the
         OS-level prefers-color-scheme on first visit. Wrapped in try/catch so
         private-mode storage errors never block the render. -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('tricho-theme');
          if (t === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
            return;
          }
          if (!t && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch (_) { /* never throw on the marketing landing */ }
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex,follow" />}

    <!-- Google Fonts — Geist Mono + Caveat are landing-only display faces;
         Fraunces / Geist / Patrick Hand are self-hosted in site.css. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Theme-color matches /shared/manifest.webmanifest so install splash and
         first paint show no color flash. -->
    <meta name="theme-color" content="#FDFAF3" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#211A15" media="(prefers-color-scheme: dark)" />

    <!-- Web App Manifest — single shared source of truth for both surfaces.
         Linked here so the install prompt can fire on the marketing landing. -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Icons. Favicon is a copper notebook with a Fraunces "T" — raster
         only (no SVG version) because the artwork is a 3D rendered image,
         not flat vector. Browsers pick the closest size.
         The ?v=2 query strings cache-bust earlier deploys (which were
         marked `Cache-Control: immutable`); bump the value any time the
         artwork changes. -->
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png?v=2" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png?v=2" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Tricho" />
    <meta property="og:locale" content="cs_CZ" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Sitemap auto-discovery -->
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <!-- JSON-LD structured data -->
    {allJsonLd.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}

    <slot name="head-extra" />
  </head>
  <body class={bodyClass}>
    <slot />

    <!-- Thin pass-through SW registration. Required for the install prompt
         to fire on the apex (Chrome/Edge/Brave/Android need a registered
         SW + manifest + HTTPS). The thin SW does NOT cache; full caching
         is handled by /app/sw.js scope /app/. -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js', { scope: '/' }).catch(function () {
            // SW unavailable (private browsing, unsupported browser) — page
            // still works fine; install prompt won't fire, but no crash.
          });
        });
      }
    </script>

    <!-- iOS install banner reveal. iOS Safari does not fire
         beforeinstallprompt, so we render a hidden hint and reveal it
         only on iOS Safari in browser mode. The banner element itself
         is rendered by the InstallBanner component on pages that include it. -->
    <script is:inline>
      (function () {
        try {
          var ua = navigator.userAgent || '';
          var isIos = /iPhone|iPad|iPod/.test(ua) && !window.MSStream;
          var isStandalone = window.navigator.standalone === true ||
            (window.matchMedia && window.matchMedia('(display-mode: standalone)').matches);
          var dismissed = false;
          try { dismissed = localStorage.getItem('install-banner-dismissed') === '1'; } catch (_) {}
          if (isIos && !isStandalone && !dismissed) {
            var b = document.querySelector('[data-install-banner]');
            if (b) b.removeAttribute('hidden');
          }
        } catch (_) { /* never throw on the marketing landing */ }
      })();
    </script>

    <!-- Launch app affordance — only visible when the marketing landing is
         loaded inside the installed PWA (display-mode: standalone). -->
    <script is:inline>
      (function () {
        try {
          var isStandalone = window.matchMedia &&
            window.matchMedia('(display-mode: standalone)').matches;
          if (isStandalone) {
            var l = document.querySelector('[data-launch-app]');
            if (l) l.removeAttribute('hidden');
          }
        } catch (_) {}
      })();
    </script>
  </body>
</html>
