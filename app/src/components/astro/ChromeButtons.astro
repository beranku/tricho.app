---
// Always-on chrome button layer. The center is pointer-events: none so taps
// pass through to the sticky day-header (which holds the date & caret).
//
// Variant 'a' = Phone A (menu + ellipsis); 'b' = Phone B (back + ellipsis).
//
// Strings come from `m.<key>()` so the SSR-baked aria-labels match the
// build-time baseLocale; the React island variant under
// `src/components/islands/ChromeButtons.tsx` re-renders these labels in
// the active locale on the client.
import ChromeGlyph from './ChromeGlyph.astro';
import Hamburger from './icons/Hamburger.astro';
import Ellipsis from './icons/Ellipsis.astro';
import BackArrow from './icons/BackArrow.astro';
import { m } from '../../i18n';

interface Props {
  variant?: 'a' | 'b';
  backHref?: string;
}
const { variant = 'a', backHref = '/' } = Astro.props;
---

<div class="chrome-buttons">
  {variant === 'a' ? (
    <ChromeGlyph label={m.chrome_openMenu()} dataAction="open-sheet:menu">
      <Hamburger />
    </ChromeGlyph>
  ) : (
    <ChromeGlyph label={m.chrome_back()} href={backHref}>
      <BackArrow />
    </ChromeGlyph>
  )}
  <ChromeGlyph label={m.chrome_more()} dataAction="open-sheet:context">
    <Ellipsis />
  </ChromeGlyph>
</div>

<style>
  .chrome-buttons {
    position: absolute;
    top: 46px;
    left: 0;
    right: 0;
    min-height: 48px;
    padding: 6px 12px 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    z-index: var(--z-chrome-buttons);
    pointer-events: none;
  }
  .chrome-buttons > :global(*) {
    pointer-events: auto;
  }
</style>
