---
/**
 * iOS Dynamic Island placeholder.
 * Pure visual — zatím žádný obsah.
 */
---

<div class="island" aria-hidden="true"></div>

<style>
  .island {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 120px;
    height: 32px;
    background: #000;
    border-radius: 20px;
    z-index: 30;
  }
</style>
