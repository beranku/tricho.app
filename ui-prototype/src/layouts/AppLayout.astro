---
import '../styles/global.css';
import PaperGrain from '../components/astro/PaperGrain.astro';

interface Props {
  title: string;
  description?: string;
  /** Přidat .stage wrapper okolo main contentu (pro desktop/prototype view) */
  stage?: boolean;
}

const { title, description = 'Trichologický deník a CRM', stage = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=no" />
    <meta name="theme-color" content="#FDFAF3" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#211A15" media="(prefers-color-scheme: dark)" />
    <meta name="description" content={description} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Inline script: aplikuje theme před první render (no flash) -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('tricho:theme');
          if (!t) {
            t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          /* storage disabled — default to light */
        }
      })();
    </script>
  </head>
  <body>
    <PaperGrain />
    {stage ? (
      <div class="stage">
        <slot />
      </div>
    ) : (
      <slot />
    )}
  </body>
</html>
