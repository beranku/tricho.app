---
interface Props {
  time: string;
  name: string;
  sub?: string;
  appointmentId?: string;
}
const { time, name, sub, appointmentId } = Astro.props;
---

<a class="slot slot-active" href={appointmentId ? `#/clients/${appointmentId}` : '#'}>
  <span class="slot-time font-fraunces tabular-nums">{time}</span>
  <span class="slot-body">
    <span class="slot-name font-fraunces">{name}</span>
    {sub && <span class="slot-sub font-geist">{sub}</span>}
  </span>
  <span class="slot-spacer" aria-hidden="true"></span>
</a>

<style>
  .slot {
    display: grid;
    grid-template-columns: 62px 1fr auto;
    align-items: start;
    gap: 16px;
    min-height: 64px;
    color: inherit;
    text-decoration: none;
  }
  .slot-active {
    background: var(--teal-tint);
    border: 1px solid var(--teal-border);
    border-radius: var(--radius-card);
    padding: 14px 16px;
    margin: 4px 4px;
    box-shadow: 0 1px 2px rgba(14, 116, 144, 0.04);
  }
  .slot-time {
    font-weight: 600;
    font-variation-settings: 'opsz' 18;
    font-size: 19px;
    color: var(--teal-strong);
    line-height: 1.1;
    padding-top: 1px;
  }
  .slot-body { display: flex; flex-direction: column; min-width: 0; }
  .slot-name {
    font-weight: 550;
    font-variation-settings: 'opsz' 36;
    font-size: 19px;
    color: var(--teal-strong);
    line-height: 1.1;
  }
  .slot-sub {
    font-size: 13px;
    color: var(--ink-3);
    margin-top: 5px;
  }
  .slot-spacer { width: 22px; }
</style>
