---
// iOS-styled status bar — time on the left, signal/wifi/battery on the right.
// Visual flourish only on the desktop preview phone; on real devices the OS
// hides this behind its own status bar.
interface Props {
  time?: string;
}
const { time = '9:41' } = Astro.props;
---

<div class="status-bar font-geist tabular-nums">
  <span>{time}</span>
  <span class="status-right">
    <svg width="16" height="11" viewBox="0 0 16 11" fill="currentColor" aria-hidden="true">
      <rect x="0" y="6" width="3" height="5" rx="0.5" />
      <rect x="4" y="4" width="3" height="7" rx="0.5" />
      <rect x="8" y="2" width="3" height="9" rx="0.5" />
      <rect x="12" y="0" width="3" height="11" rx="0.5" />
    </svg>
    <svg width="16" height="11" viewBox="0 0 16 11" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
      <path d="M1 4 C 5 0, 11 0, 15 4" />
      <path d="M3 6 C 6 3, 10 3, 13 6" />
      <path d="M5 8 C 7 6, 9 6, 11 8" />
      <circle cx="8" cy="10" r="0.7" fill="currentColor" stroke="none" />
    </svg>
    <svg width="25" height="11" viewBox="0 0 25 11" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
      <rect x="0.5" y="0.5" width="20" height="10" rx="2" />
      <rect x="2" y="2" width="14" height="7" rx="1" fill="currentColor" stroke="none" />
      <path d="M22 4 L22 7" stroke-width="1.4" stroke-linecap="round" />
    </svg>
  </span>
</div>

<style>
  .status-bar {
    position: absolute;
    top: 14px;
    left: 0;
    right: 0;
    padding: 0 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    z-index: var(--z-status-bar);
    pointer-events: none;
  }
  .status-right {
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .status-right svg {
    color: var(--ink);
  }
</style>
