---
// Default scheduled slot. SlotDone / SlotActive / SlotFree are variant wrappers.
interface Props {
  time: string;   // "10:30"
  name: string;   // "Klára Dvořáková"
  sub?: string;   // "Diagnostika"
  appointmentId?: string;
}
const { time, name, sub, appointmentId } = Astro.props;
---

<a class="slot" href={appointmentId ? `#/clients/${appointmentId}` : '#'} data-appointment-id={appointmentId}>
  <span class="slot-time font-fraunces tabular-nums">{time}</span>
  <span class="slot-body">
    <span class="slot-name font-fraunces">{name}</span>
    {sub && <span class="slot-sub font-geist">{sub}</span>}
  </span>
  <span class="slot-spacer" aria-hidden="true"></span>
</a>

<style>
  .slot {
    display: grid;
    grid-template-columns: 62px 1fr auto;
    align-items: start;
    padding: 14px 20px;
    gap: 16px;
    min-height: 64px;
    color: inherit;
    text-decoration: none;
  }
  .slot-time {
    font-weight: 600;
    font-variation-settings: 'opsz' 18;
    font-size: 19px;
    color: var(--ink-2);
    line-height: 1.1;
    padding-top: 1px;
  }
  .slot-body {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .slot-name {
    font-weight: 500;
    font-variation-settings: 'opsz' 36;
    font-size: 19px;
    color: var(--ink);
    line-height: 1.1;
  }
  .slot-sub {
    font-size: 13px;
    color: var(--ink-3);
    margin-top: 5px;
    font-weight: 400;
  }
  .slot-spacer {
    width: 22px;
  }
</style>
