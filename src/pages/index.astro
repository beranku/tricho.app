---
/**
 * Main Application Page
 *
 * This page integrates the React TrichoApp component into Astro with proper
 * client-side hydration. The TrichoApp component handles:
 * - Authentication state management
 * - Setup flow with passkey registration
 * - Login flow with passkey authentication
 * - Main CRM interface when authenticated
 *
 * Uses client:load to ensure React hydrates immediately on page load,
 * which is necessary for the auth state to be checked and the app
 * to be interactive as soon as possible.
 *
 * @module pages/index
 */
import Layout from '../layouts/Layout.astro';
import TrichoApp from '../components/TrichoApp';
---

<Layout title="TrichoApp">
  <TrichoApp client:load />
</Layout>

<style is:global>
  /* TrichoApp Container Styles */
  .tricho-app {
    min-height: 100vh;
  }

  /* Main Content Layout */
  .main-content {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .main-content-header {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: var(--color-surface, #ffffff);
    border-bottom: 1px solid var(--color-border, #e5e5e5);
  }

  .main-content-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text, #1a1a1a);
  }

  .main-content-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .main-content-body {
    flex: 1;
    padding: 1rem;
    background: var(--color-background, #f5f5f5);
  }

  /* =========================================================================
   * Login Screen Styles
   * ========================================================================= */

  .login-screen {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: linear-gradient(135deg, var(--color-primary-light, #e8f5e9) 0%, var(--color-surface, #ffffff) 100%);
  }

  .login-content {
    width: 100%;
    max-width: 400px;
    padding: 2rem;
    background: var(--color-surface, #ffffff);
    border-radius: 1rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .login-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .login-passkey-icon {
    color: var(--color-primary, #2e7d32);
    margin-bottom: 1rem;
  }

  .login-title {
    margin: 0 0 0.5rem;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text, #1a1a1a);
  }

  .login-subtitle {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-text-secondary, #666666);
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .login-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .login-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text, #1a1a1a);
  }

  .login-input {
    padding: 0.75rem 1rem;
    font-size: 1rem;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 0.5rem;
    background: var(--color-surface, #ffffff);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .login-input:focus {
    outline: none;
    border-color: var(--color-primary, #2e7d32);
    box-shadow: 0 0 0 3px rgba(46, 125, 50, 0.1);
  }

  .login-input:disabled {
    background: var(--color-background, #f5f5f5);
    opacity: 0.7;
    cursor: not-allowed;
  }

  .login-error {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.75rem;
    background: var(--color-error-light, #ffebee);
    border-radius: 0.5rem;
    color: var(--color-error, #d32f2f);
    font-size: 0.875rem;
  }

  .login-error-icon {
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .login-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: background-color 0.15s ease, transform 0.1s ease;
  }

  .login-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .login-button:not(:disabled):active {
    transform: scale(0.98);
  }

  .login-button--primary {
    background: var(--color-primary, #2e7d32);
    color: white;
  }

  .login-button--primary:not(:disabled):hover {
    background: var(--color-primary-dark, #1b5e20);
  }

  .login-button--secondary {
    background: var(--color-background, #f5f5f5);
    color: var(--color-text, #1a1a1a);
  }

  .login-button--secondary:not(:disabled):hover {
    background: var(--color-border, #e5e5e5);
  }

  .login-button--text {
    background: transparent;
    color: var(--color-primary, #2e7d32);
    padding: 0.5rem 1rem;
  }

  .login-button--text:not(:disabled):hover {
    background: rgba(46, 125, 50, 0.08);
  }

  .login-spinner {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .login-recovery {
    margin-top: 1.5rem;
    text-align: center;
  }

  .login-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    color: var(--color-text-secondary, #666666);
    font-size: 0.875rem;
  }

  .login-divider::before,
  .login-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border, #e5e5e5);
  }

  .login-footer {
    margin-top: 2rem;
    text-align: center;
  }

  .login-security-note {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin: 0;
    font-size: 0.8125rem;
    color: var(--color-text-secondary, #666666);
  }

  .login-loading {
    text-align: center;
    padding: 2rem;
  }

  .login-loading p {
    margin-top: 1rem;
    color: var(--color-text-secondary, #666666);
  }

  .login-unsupported {
    text-align: center;
    padding: 1rem;
  }

  .login-unsupported h2 {
    margin: 1rem 0 0.5rem;
    color: var(--color-error, #d32f2f);
  }

  .login-unsupported p {
    color: var(--color-text-secondary, #666666);
  }

  .login-prf-warnings {
    margin-bottom: 1rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary, #666666);
  }

  .login-prf-warnings summary {
    cursor: pointer;
    color: var(--color-primary, #2e7d32);
  }

  .login-prf-warnings ul {
    margin: 0.5rem 0 0;
    padding-left: 1.5rem;
  }

  /* =========================================================================
   * App Shell Styles
   * ========================================================================= */

  .app-loading,
  .app-error,
  .app-crash,
  .app-placeholder {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    text-align: center;
  }

  .app-loading-spinner {
    margin-bottom: 1rem;
  }

  .app-loading-icon {
    animation: spin 1s linear infinite;
    color: var(--color-primary, #2e7d32);
  }

  .app-loading-text {
    margin: 0;
    color: var(--color-text-secondary, #666666);
  }

  .app-error-content,
  .app-crash-content,
  .app-placeholder-content {
    max-width: 400px;
    padding: 2rem;
    background: var(--color-surface, #ffffff);
    border-radius: 1rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .app-error-icon {
    color: var(--color-error, #d32f2f);
    margin-bottom: 1rem;
  }

  .app-error-title {
    margin: 0 0 0.5rem;
    color: var(--color-text, #1a1a1a);
  }

  .app-error-message {
    margin: 0 0 1.5rem;
    color: var(--color-text-secondary, #666666);
  }

  .app-error-retry {
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    background: var(--color-primary, #2e7d32);
    color: white;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
  }

  .app-error-retry:hover {
    background: var(--color-primary-dark, #1b5e20);
  }

  /* Recovery Reminder Banner */
  .recovery-reminder {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 1rem;
    background: var(--color-warning-light, #fff3e0);
    border-top: 1px solid var(--color-warning, #f57c00);
  }

  .recovery-reminder-content {
    display: flex;
    align-items: center;
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .recovery-reminder-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .recovery-reminder-text strong {
    color: var(--color-text, #1a1a1a);
  }

  .recovery-reminder-text span {
    font-size: 0.875rem;
    color: var(--color-text-secondary, #666666);
  }

  .recovery-reminder-actions {
    display: flex;
    gap: 0.5rem;
  }

  .recovery-reminder-save,
  .recovery-reminder-dismiss {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    border: none;
    border-radius: 0.375rem;
    cursor: pointer;
  }

  .recovery-reminder-save {
    background: var(--color-warning, #f57c00);
    color: white;
  }

  .recovery-reminder-dismiss {
    background: transparent;
    color: var(--color-text-secondary, #666666);
  }

  /* Responsive adjustments */
  @media (min-width: 768px) {
    .main-content-header {
      padding: 1rem 1.5rem;
    }

    .main-content-body {
      padding: 1.5rem;
    }

    .main-content-title {
      font-size: 1.5rem;
    }
  }

  /* Safe area support for iOS PWA */
  @supports (padding: env(safe-area-inset-top)) {
    .main-content-header {
      padding-top: calc(0.75rem + env(safe-area-inset-top));
      padding-left: calc(1rem + env(safe-area-inset-left));
      padding-right: calc(1rem + env(safe-area-inset-right));
    }

    .main-content-body {
      padding-bottom: calc(1rem + env(safe-area-inset-bottom));
    }

    .recovery-reminder {
      padding-bottom: calc(1rem + env(safe-area-inset-bottom));
    }

    @media (min-width: 768px) {
      .main-content-header {
        padding-top: calc(1rem + env(safe-area-inset-top));
        padding-left: calc(1.5rem + env(safe-area-inset-left));
        padding-right: calc(1.5rem + env(safe-area-inset-right));
      }

      .main-content-body {
        padding-bottom: calc(1.5rem + env(safe-area-inset-bottom));
      }
    }
  }
</style>
