---
interface Props {
  title?: string;
}

const { title = 'TrichoApp' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <title>{title}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#FDFAF3" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#211A15" media="(prefers-color-scheme: dark)" />
  <link rel="manifest" href={`${base}manifest.webmanifest`} />
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

  <!-- Anti-flash theme bootstrap. Reads `_local/theme` from PouchDB on
       cold load (when available) and falls back to OS preference. Runs
       synchronously before paint. Inlined to avoid an extra fetch. -->
  <script is:inline>
    (function () {
      try {
        var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (prefersDark) document.documentElement.dataset.theme = 'dark';

        // Lazy: open the same IndexedDB PouchDB uses, look up _local/theme.
        // Doing this synchronously is impossible — IndexedDB is async — but we
        // kick the read off as early as possible and replace `data-theme`
        // before first paint where we can.
        var req = indexedDB.open('_pouch_tricho_app_prefs');
        req.onsuccess = function (ev) {
          var db = ev.target.result;
          if (!db.objectStoreNames.contains('document-store')) { db.close(); return; }
          var tx = db.transaction('document-store', 'readonly');
          var store = tx.objectStore('document-store');
          var get = store.get('_local/theme');
          get.onsuccess = function () {
            var doc = get.result && get.result.data;
            if (doc && doc.theme === 'dark') {
              document.documentElement.dataset.theme = 'dark';
            } else if (doc && doc.theme === 'light') {
              delete document.documentElement.dataset.theme;
            }
            db.close();
          };
        };
      } catch (_) { /* fall back to default light */ }
    })();
  </script>
</head>
<body>
  <div class="paper-grain"></div>
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
