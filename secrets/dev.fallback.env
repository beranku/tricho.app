# Plain-text dev fallback values used by `make _render-secrets` when
# `secrets/dev.sops.yaml` does not yet exist.
#
# This file is committed. Nothing here is a real secret — `changeme`,
# `dev-cookie-secret`, and the placeholder OAuth secrets are intentionally
# identifiable as dev-only.
#
# Once you have an age keypair and have authored secrets/dev.sops.yaml,
# this fallback is ignored.

couchdb_password=changeme
cookie_secret=dev-cookie-secret-do-not-use-in-prod
google_client_secret=
apple_client_secret=
