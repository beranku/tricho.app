# Cloudflare Pages per-route response headers.
#
# Cache-Control strategy: hashed assets are immutable for a year; HTML and
# both service workers are no-cache so launches propagate within the next
# request. Manifest sits in the middle (1 hour) so name/icon updates land
# without an aggressive bust.
#
# Service-Worker-Allowed lets a SW claim a wider scope than its filesystem
# location implies; we set it explicitly on both SW paths.
#
# Security headers apply globally; the CSP is scoped to /app/* (the app
# shell handles plaintext in memory and is the surface where XSS would
# leak the in-memory DEK). Marketing pages are static HTML+CSS with no
# sensitive surface, so a tighter CSP than the global headers there isn't
# necessary.

# ── Service workers ──────────────────────────────────────────────────────────
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

/app/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /app/

# ── Web App Manifest ─────────────────────────────────────────────────────────
/manifest.webmanifest
  Cache-Control: public, max-age=3600
  Content-Type: application/manifest+json

# ── Hashed, content-addressed assets — immutable ─────────────────────────────
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/app/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/app/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Icon files share stable URLs across releases (favicon.svg, icon-192.png,
# etc.), so they CANNOT be `immutable` — once we replace the artwork, every
# stale browser/CDN cache would otherwise hold the previous icon for a year.
# 1-day max-age + standard revalidation is the right balance: still cached
# for performance, but a new deploy lands within 24 h. Cache-bust at the
# HTML / manifest layer (`?v=N` on each icon URL) for instant rollout.
/icons/*
  Cache-Control: public, max-age=86400, must-revalidate

/og/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/app/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# ── HTML — short cache, must revalidate ──────────────────────────────────────
/
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/app/*
  Cache-Control: public, max-age=0, must-revalidate

# ── Global security headers ──────────────────────────────────────────────────
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# ── Stricter CSP for the PWA shell ───────────────────────────────────────────
# 'unsafe-inline' on script-src is required because Astro Islands ships its
# hydration bootstrap (window.Astro setup + the astro-island custom element
# definition) AND our SW/theme bootstraps as inline <script> blocks in the
# SSR'd HTML. Without it, no React component ever hydrates and the SSR
# fallback ("Loading keystore…") stays visible forever. A nonce/strict-
# dynamic migration would let us drop this — Astro doesn't emit per-script
# nonces today and Cloudflare Pages _headers is static, so any hash-based
# CSP would need a build-time generator. Tracked as follow-up.
#
# 'unsafe-inline' on style-src is required because the React tree uses
# inline style= attributes for design-token-driven dynamics (e.g. color
# computed from a copper token + opacity).
#
# connect-src includes the sync subdomains so the PWA on tricho.app /
# dev.tricho.app can credentialed-fetch the cross-origin server-side stack
# at sync.tricho.app / sync.dev.tricho.app (auth proxy + CouchDB userdb
# + replicator). 'wasm-unsafe-eval' covers any future Workbox WASM
# precaching.
/app/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://sync.tricho.app https://sync.dev.tricho.app; worker-src 'self'; manifest-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'
