# Non-sensitive committed defaults for `docker compose`.
# Secrets DO NOT belong here — use secrets/<profile>.sops.yaml (section 5).

# Hostname the stack serves under. `tricho.localhost` resolves to 127.0.0.1
# on macOS/Linux/Windows without any /etc/hosts editing (RFC 6761).
APP_HOST=tricho.localhost
APP_ORIGIN=https://tricho.localhost

# Meta DB name inside CouchDB — tricho-auth ensures this exists at boot.
TRICHO_META_DB=tricho_meta

# Host-published debug ports (dev only — section 3.5 gates these).
COUCHDB_PORT=5984
AUTH_PROXY_PORT=4545

# Traefik settings.
TRAEFIK_LOG_LEVEL=INFO
# In prod, point this at a real inbox. In dev this value is never used
# (dev profile skips Let's Encrypt entirely).
TRAEFIK_ACME_EMAIL=admin@example.com

# Built Astro bundle — Caddy mounts this read-only in prod/ci profiles.
PWA_DIST_DIR=./dist

# Compose project name: keeps volume + container prefixes predictable.
COMPOSE_PROJECT_NAME=tricho
