# =============================================================================
# TrichoApp Frontend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!
#
# For Supabase credentials:
# - Self-hosted: Use values from infrastructure/.env
# - Cloud: Get from https://supabase.com/dashboard/project/_/settings/api
# =============================================================================

# =============================================================================
# SUPABASE (Required for sync features)
# =============================================================================
# Supabase API URL
# Self-hosted example: https://api.tricho.example.com
# Cloud example: https://xxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anonymous (public) key
# This key is safe to expose in the frontend - RLS policies enforce security
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# DEBUG & DEVELOPMENT (Optional)
# =============================================================================
# Enable debug logging (true/false)
# Shows detailed logs in browser console for troubleshooting
VITE_DEBUG=false

# Enable development mode features (true/false)
# Enables additional dev tools and bypasses some production restrictions
VITE_DEV_MODE=false
