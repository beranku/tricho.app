# Template for .env.local — personal/host-specific overrides.
#
# The repo ships a committed `.env` with non-sensitive defaults that work out
# of the box. If you need to override something on your machine (different
# port, different hostname, a prod-ish APP_HOST for testing), copy this file
# to `.env.local` and edit — both are loaded by the Makefile, with `.env.local`
# winning on conflicts.
#
#   cp .env.example .env.local && $EDITOR .env.local
#
# Secrets DO NOT belong here or in `.env`. See `secrets/README.md` (section 5
# of the unified-stack-orchestration change) for the SOPS+age workflow.

# Hostname — override for a different local hostname (e.g. mkcert-backed HTTPS).
#APP_HOST=tricho.localhost
#APP_ORIGIN=https://tricho.localhost

# Expose CouchDB / tricho-auth on different ports if 5984/4545 conflict.
#COUCHDB_PORT=5984
#AUTH_PROXY_PORT=4545

# Set a real inbox when running `make prod-local` against a real domain so
# Let's Encrypt can mail you about expiring certs.
#TRAEFIK_ACME_EMAIL=you@example.com

# Point at an alternate built bundle (e.g. a stage-specific dist).
#PWA_DIST_DIR=./dist
