# TrichoApp Environment Configuration
# Copy this file to .env and fill in your values

# =============================================
# Client-side URLs (exposed to browser via Vite)
# =============================================

# CouchDB server URL for document replication
VITE_COUCHDB_URL=http://localhost:5984

# Auth service URL for WebAuthn endpoints
VITE_AUTH_URL=http://localhost:3000

# Object storage URL for encrypted photo blobs (S3-compatible)
VITE_OBJECT_STORAGE_URL=http://localhost:9000

# =============================================
# Server-side only (NOT exposed to browser)
# =============================================

# CouchDB admin credentials (for server-side database creation)
COUCHDB_USER=admin
COUCHDB_PASSWORD=your-secure-password-here

# Object storage credentials (S3-compatible)
OBJECT_STORAGE_ACCESS_KEY=your-access-key
OBJECT_STORAGE_SECRET_KEY=your-secret-key
OBJECT_STORAGE_BUCKET=tricho-photos

# JWT signing secret for auth tokens
JWT_SECRET=your-jwt-secret-here

# =============================================
# Optional development settings
# =============================================

# Enable debug logging (client-side)
VITE_DEBUG=false

# Skip HTTPS requirement in development
VITE_DEV_MODE=true
