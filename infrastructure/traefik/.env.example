# Copy to .env or export before `docker compose up`.
# All of these are required when the Traefik overlay is enabled.
APP_HOST=tricho.example.com
TRAEFIK_ACME_EMAIL=admin@example.com
TRAEFIK_LOG_LEVEL=INFO
# Absolute path (or relative to this directory) pointing at the built PWA
# bundle. Defaults to ../../dist, which is what `npm run build` produces.
PWA_DIST_DIR=../../dist
COUCHDB_USER=admin
COUCHDB_PASSWORD=replace-with-strong-secret
