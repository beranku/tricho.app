# Caddy is used here purely as a static file server behind Traefik. It serves
# the PWA bundle; TLS/ACME is handled by Traefik at the edge.
#
# After marketing-site-and-pwa-split: the PWA is built with base: '/app/', so
# its emitted HTML references /app/_astro/*. To serve correctly behind Traefik
# at https://tricho.test/app/*, we mount the dist under /app via rewrite.
# Marketing pages at https://tricho.test/ are the responsibility of the
# Cloudflare Pages deploy, not this local stack — so a request to / from
# inside the docker stack returns the PWA's index.html (the e2e tests only
# care about /app/* anyway).
:80 {
    root * /srv
    encode zstd gzip

    # Strip the /app/ prefix so Caddy can find files in /srv (which contains
    # the dist's flat index.html / _astro / sw.js / etc., with no /app/
    # prefix on the filesystem). This matches Cloudflare Pages' behaviour
    # where the PWA build output is placed under dist/app/ before deploy.
    @app path /app /app/*
    rewrite @app /{path}
    uri @app strip_prefix /app

    try_files {path} /index.html
    file_server
    header {
        Cache-Control "public, max-age=600, must-revalidate"
    }
    @assets {
        path /_astro/* /favicon.svg /manifest.webmanifest /sw.js /icons/* /fonts/*
    }
    header @assets Cache-Control "public, max-age=31536000, immutable"
    @sw path /sw.js
    header @sw Service-Worker-Allowed "/app/"
}
