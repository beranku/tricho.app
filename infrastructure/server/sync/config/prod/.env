# Production sync stack: sync.tricho.app, paired with PWA on https://tricho.app

APP_HOST=sync.tricho.app
APP_ORIGIN=https://tricho.app
TRICHO_AUTH_CORS_MIDDLEWARE=tricho-cors-prod

# Real OAuth values land here. CLIENT_ID is non-secret (it's in the
# redirect URL anyway); CLIENT_SECRET comes from secrets/sync-prod.sops.yaml.
GOOGLE_CLIENT_ID=
GOOGLE_REDIRECT_URI=https://sync.tricho.app/auth/google/callback
GOOGLE_ISSUER_URL=https://accounts.google.com

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_REDIRECT_URI=https://sync.tricho.app/auth/apple/callback

# Stripe price IDs (non-secret). The secret key comes from SOPS.
PLAN_PRO_MONTHLY_STRIPE_PRICE_ID=
PLAN_PRO_YEARLY_STRIPE_PRICE_ID=
PLAN_MAX_MONTHLY_STRIPE_PRICE_ID=
PLAN_MAX_YEARLY_STRIPE_PRICE_ID=

# Set the operator's email so Let's Encrypt can warn about expiring certs.
# This is consumed by the edge stack's compose, not the sync stack — but
# repeating it here means the sync deploy's env render is one-stop-shop.
TRAEFIK_ACME_EMAIL=
