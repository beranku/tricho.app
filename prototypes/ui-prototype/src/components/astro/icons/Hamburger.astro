---
interface Props {
  size?: number;
}
const { size = 22 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <line x1="4" y1="8" x2="20" y2="8" />
  <line x1="4" y1="12" x2="20" y2="12" />
  <line x1="4" y1="16" x2="20" y2="16" />
</svg>
