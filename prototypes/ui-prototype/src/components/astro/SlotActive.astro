---
import { formatTime } from '../../lib/format/time';

/**
 * Aktivní slot — zákrok právě probíhá. Teal tint pozadí + teal text.
 * Margin 4px 4px (mírný inset od kraje telefonu), border-radius 14px.
 */
interface Props {
  startAt: Date;
  clientName: string;
  services: string[];
  href?: string;
}

const { startAt, clientName, services, href } = Astro.props;
const timeStr = formatTime(startAt);
const servicesStr = services.join(', ');
---

<a class="slot slot-active" href={href}>
  <span class="ty-slot-time slot-time-active">{timeStr}</span>
  <div class="slot-content">
    <div class="ty-slot-name slot-name-active nowrap">{clientName}</div>
    {servicesStr && <div class="ty-slot-sub">{servicesStr}</div>}
  </div>
  <span></span>
</a>

<style>
  .slot {
    display: grid;
    grid-template-columns: 62px 1fr auto;
    align-items: start;
    gap: 16px;
    min-height: 64px;
    color: inherit;
    text-decoration: none;
  }
  .slot-content {
    min-width: 0;
  }
  .slot-active {
    background: var(--teal-tint);
    border: 1px solid var(--teal-border);
    border-radius: var(--radius-card);
    padding: 14px 16px;
    margin: 4px 4px;
    box-shadow: 0 1px 2px rgba(14, 116, 144, 0.04);
  }
  .slot-time-active {
    color: var(--teal-strong);
  }
  .slot-name-active {
    color: var(--teal-strong);
    font-weight: 550;
  }
</style>
