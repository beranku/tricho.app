---
import CheckHandDrawn from './icons/CheckHandDrawn.astro';
import { formatTime } from '../../lib/format/time';

/**
 * Dokončený slot (past appointment). Ztlumené barvy, copper check vpravo.
 */
interface Props {
  startAt: Date;
  clientName: string;
  services: string[];
  href?: string;
}

const { startAt, clientName, services, href } = Astro.props;
const timeStr = formatTime(startAt);
const servicesStr = services.join(', ');
---

<a class="slot slot-done" href={href}>
  <span class="ty-slot-time">{timeStr}</span>
  <div class="slot-content">
    <div class="ty-slot-name nowrap">{clientName}</div>
    {servicesStr && <div class="ty-slot-sub">{servicesStr}</div>}
  </div>
  <span class="slot-done-check">
    <CheckHandDrawn size={14} />
  </span>
</a>

<style>
  .slot {
    display: grid;
    grid-template-columns: 62px 1fr auto;
    align-items: start;
    padding: 14px 20px;
    gap: 16px;
    min-height: 64px;
    color: inherit;
    text-decoration: none;
  }
  .slot-content {
    min-width: 0;
  }
  .slot-done {
    opacity: 0.55;
  }
  .slot-done .ty-slot-time {
    color: var(--ink-4);
    font-weight: 550;
  }
  .slot-done .ty-slot-name {
    color: var(--ink-3);
    font-weight: 500;
  }
  .slot-done .ty-slot-sub {
    color: var(--ink-4);
  }
  .slot-done-check {
    color: var(--copper-mid);
    width: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .slot:active {
    opacity: 0.7;
    background: var(--surface-2);
  }
</style>
