---
/**
 * iOS-style status bar — čas vlevo, signál/wifi/baterka vpravo.
 * Absolute positioned over phone-inner, z-index 28 (pod Island 30).
 */
interface Props {
  time?: string;
}
const { time = '10:35' } = Astro.props;
---

<div class="status-bar">
  <span>{time}</span>
  <div class="status-right">
    <!-- Signal -->
    <svg width="17" height="11" viewBox="0 0 17 11" fill="currentColor" aria-hidden="true">
      <rect x="0" y="6" width="3" height="5" rx="0.5" />
      <rect x="4.5" y="4" width="3" height="7" rx="0.5" />
      <rect x="9" y="2" width="3" height="9" rx="0.5" />
      <rect x="13.5" y="0" width="3" height="11" rx="0.5" />
    </svg>
    <!-- Wifi -->
    <svg width="16" height="11" viewBox="0 0 16 11" fill="none" aria-hidden="true">
      <path
        d="M8 10.5 C 4 7, 1 5, 1 3 C 1 1.5, 2.5 1, 4 2 C 5.5 3, 7 4, 8 5.5 C 9 4, 10.5 3, 12 2 C 13.5 1, 15 1.5, 15 3 C 15 5, 12 7, 8 10.5 Z"
        stroke="currentColor"
        stroke-width="1"
        fill="none"
      />
    </svg>
    <!-- Battery -->
    <svg width="25" height="12" viewBox="0 0 25 12" fill="none" aria-hidden="true">
      <rect x="0.5" y="1" width="21" height="10" rx="2.5" stroke="currentColor" fill="none" />
      <rect x="2.5" y="3" width="17" height="6" rx="1" fill="currentColor" />
      <rect x="22.5" y="4" width="1.5" height="4" rx="0.5" fill="currentColor" />
    </svg>
  </div>
</div>

<style>
  .status-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 46px;
    padding: 14px 28px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: 'Geist', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
    z-index: 28;
    pointer-events: none;
  }
  .status-right {
    display: flex;
    align-items: center;
    gap: 6px;
  }
</style>
